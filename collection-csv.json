    {
      "name": "post",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// 1. 生成随机 userId (1-10之间，强制转为数字类型)",
              "var randomUserId = Number(Math.floor(Math.random() * 10) + 1);",
              "// 2. 明确将变量存入「当前环境」（优先）或「全局环境」",
              "pm.environment.set(\"randomUserId\", randomUserId); ",
              "// 可选：同时存入全局环境，避免作用域问题",
              "pm.globals.set(\"randomUserId\", randomUserId);",
              "",
              "// 3. 生成随机标题（字符串类型）",
              "var randomTitle = \"Test Title \" + Math.random().toString(36).substring(2, 8);",
              "pm.environment.set(\"randomTitle\", randomTitle);",
              "pm.globals.set(\"randomTitle\", randomTitle);",
              "",
              "// 4. 生成随机正文",
              "var randomBody = \"Test Body content: \" + new Date().toISOString();",
              "pm.environment.set(\"randomBody\", randomBody);",
              "pm.globals.set(\"randomBody\", randomBody);",
              "",
              "// 调试：打印变量值，方便排查（在Console里看）",
              "console.log(\"生成的userId（数字）:\", randomUserId, typeof randomUserId);",
              "console.log(\"环境变量里的userId:\", pm.environment.get(\"randomUserId\"), typeof pm.environment.get(\"randomUserId\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 校验响应状态码",
              "pm.test(\"响应状态码为201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// 校验返回的title与请求一致（增加兜底）",
              "pm.test(\"返回的title与请求一致\", function () {",
              "    var jsonData = pm.response.json();",
              "    // 先获取变量，没有则用空字符串兜底",
              "    var requestTitle = pm.environment.get(\"randomTitle\") || pm.globals.get(\"randomTitle\") || \"\";",
              "    pm.expect(jsonData.title).to.eql(requestTitle);",
              "});",
              "",
              "// 校验返回的userId与请求一致（核心修复：统一类型+兜底）",
              "pm.test(\"返回的userld与请求一致\", function () {",
              "    var jsonData = pm.response.json();",
              "    // 1. 获取请求时的userId（优先环境变量，再全局，转数字）",
              "    var requestUserId = Number(pm.environment.get(\"randomUserId\") || pm.globals.get(\"randomUserId\") || 0);",
              "    // 2. 获取响应里的userId（确保是数字）",
              "    var responseUserId = Number(jsonData.userld);",
              "    // 3. 断言（增加日志，方便调试）",
              "    console.log(\"请求userId:\", requestUserId, \"响应userId:\", responseUserId);",
              "    pm.expect(responseUserId).to.eql(requestUserId);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
