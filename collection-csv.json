          "listen": "test",
          "script": {
            "exec": [
              "//校验状态码是200",
              "pm.test(\"响应状态码为200\",function(){",
              "    pm.response.to.have.status(200);",
              "})",
              "//校验返回的JSON数据",
              "pm.test(\"返回正确的JSON结构\",function(){",
              "    var jsonDate = pm.response.json();",
              "pm.expect(jsonDate).to.have.property(\"userld\");",
              "pm.expect(jsonDate).to.have.property(\"id\");",
              "pm.expect(jsonDate).to.have.property(\"title\");",
              "pm.expect(jsonDate).to.have.property(\"completed\");",
              "});",
              "//校验字段类型和值",
              "pm.test(\"userld为数字且等于1\",function(){",
              "    var jsonDate = pm.response.json();",
              "    pm.expect(jsonDate.userld).to.eql(1);",
              "pm.expect(jsonDate.userld).to.be.a(\"number\");",
              "});",
              "pm.test(\"id为数字且等于1\",function(){",
              "    var jsonDate = pm.response.json();",
              "pm.expect(jsonDate.id).to.eql(1);",
              "pm.expect(jsonDate.id).to.be.a(\"number\");",
              "});",
              "pm.test(\"title为字符串是delectus aut autem\",function(){",
              "    var jsonDate = pm.response.json();",
              "pm.expect(jsonDate.title).to.eql(\"修改后的标题\");",
              "pm.expect(jsonDate.title).to.be.a(\"string\");",
              "});",
              "pm.test(\"completed是布尔值false\",function(){",
              "    var jsonDate = pm.response.json();",
              "pm.expect(jsonDate.completed).to.eql(true);",
              "pm.expect(jsonDate.completed).to.be.a(\"boolean\");",
              "",
              "});",
              "var jsonDate = pm.response.json();",
              "pm.collectionVariables.set(\"todold\",jsonDate.id)",
              ""
            ],
