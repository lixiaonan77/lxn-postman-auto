    {
      "name": "用户名密码正确，登录成功",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. 先尝试解析响应，防止非JSON格式导致脚本报错",
              "var jsonData = {};",
              "try {",
              "    jsonData = pm.response.json();",
              "} catch (e) {",
              "    pm.test(\"响应格式不是JSON，请检查接口地址\", function () {",
              "        pm.expect.fail(\"接口返回了HTML，可能被防火墙拦截了\");",
              "    });",
              "}",
              "",
              "// 2. 断言状态码为200",
              "pm.test(\"登录成功，状态码为200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// 3. 断言响应包含token字段",
              "pm.test(\"响应包含token\", function () {",
              "    pm.expect(jsonData.token).to.exist;",
              "    console.log(\"获取到的Token是：\", jsonData.token); // 在控制台打印，方便你看",
              "});",
              "",
              "// 4. 将token设置到环境变量中（关键步骤）",
              "// 确保你右上角的环境是 \"ReqRes_Test\"",
              "pm.environment.set(\"access_token\", jsonData.token);",
              "// 基础断言",
              "pm.test(\"状态码为200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"返回数据不为空\", function () {",
              "  pm.response.json();",
              "});",
              "",
              "// 高级断言1：接口速度",
              "pm.test(\"接口响应时间小于500ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "// 高级断言2：字段必须存在",
              "",
              "pm.test(\"返回包含data\", function () {",
              "  pm.expect(pm.response.json()).to.have.property(\"token\");",
              "});",
              "",
              "// 高级断言3：业务成功",
              "//pm.test(\"业务执行成功\", function () {",
              "//  pm.expect(pm.response.json().code).to.eql(200);",
              "//});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
