    {
      "name": "post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. 断言状态码为201（创建成功）",
              "pm.test(\"创建帖子成功，状态码为201\", function() {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// 2. 断言响应包含我们提交的id和email字段",
              "var jsonData = pm.response.json();",
              "pm.test(\"响应包含提交的id\", function() {",
              "    pm.expect(jsonData.id).to.eql(101); // 你提交的id是101",
              "});",
              "pm.test(\"响应包含提交的email\", function() {",
              "    pm.expect(jsonData.email).to.eql(\"eve.holt@reqres.in\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
