              "});",
              "",
              "// 高级断言2：字段必须存在",
              "pm.test(\"返回包含email\", function () {",
              "  pm.expect(pm.response.json()).to.have.property(\"email\");",
              "});",
              "",
              "pm.test(\"返回包含name\", function () {",
              "  pm.expect(pm.response.json()).to.have.property(\"name\");",
              "});",
              "",
              "// 高级断言3：业务成功",
              "pm.test(\"业务执行成功\", function () {",
              "  pm.expect(pm.response.json().name).to.eql(\"Eve Holt\");",
              "});"
